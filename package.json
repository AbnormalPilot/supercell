{
  "name": "supercell",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@supercell/web",
    "dev:video": "turbo dev --filter=@supercell/video",
    "build": "turbo build",
    "build:web": "turbo build --filter=@supercell/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "dev:api": "uv run python apps/api/main.py",
    "test:py": "uv run python -m pytest apps/api/tests/ -v",
    "test": "turbo test && uv run python -m pytest apps/api/tests/ -v",
    "check": "turbo typecheck && uv run python -m pytest apps/api/tests/ -q"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
